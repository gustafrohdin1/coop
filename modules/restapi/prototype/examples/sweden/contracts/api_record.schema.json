{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/api_record.schema.json",
  "title": "ApiRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "api_id",
    "stable_source_identifier",
    "title",
    "provider",
    "provider_type",
    "source_portal",
    "source_url",
    "description",
    "domain_tags",
    "geography",
    "auth_model",
    "interface_type",
    "distribution_formats",
    "update_frequency",
    "license",
    "api_confidence",
    "metadata_completeness",
    "search_keywords",
    "source_trust_tier",
    "provenance"
  ],
  "properties": {
    "api_id": {
      "type": "string",
      "pattern": "^[a-z0-9._:-]+$"
    },
    "stable_source_identifier": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "provider_type": {
      "type": "string",
      "enum": [
        "state_agency",
        "municipality",
        "region",
        "public_company",
        "university",
        "mixed_catalog",
        "private_or_civil_source",
        "unknown"
      ]
    },
    "source_portal": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "documentation_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "access_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "domain_tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "transport",
          "geospatial",
          "health",
          "education",
          "environment",
          "economy",
          "business_and_procurement",
          "demographics",
          "justice_and_civic",
          "culture_and_heritage",
          "research",
          "utilities_and_infrastructure",
          "cross_domain",
          "unknown"
        ]
      }
    },
    "geography": {
      "type": "string",
      "enum": ["se", "regional", "municipal", "multi", "unknown"]
    },
    "auth_model": {
      "type": "string",
      "enum": ["open_no_auth", "open_api_key", "authenticated_public", "restricted", "unclear"]
    },
    "interface_type": {
      "type": "string",
      "enum": ["rest", "graphql", "sparql", "soap", "odata", "file_download_only", "bulk_download", "unknown"]
    },
    "distribution_formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["json", "xml", "rdf", "csv", "geojson", "zip", "html", "unknown"]
      }
    },
    "update_frequency": {
      "type": "string",
      "enum": ["realtime", "daily", "weekly", "monthly", "irregular", "unknown"]
    },
    "license": {
      "type": "string",
      "minLength": 1
    },
    "api_confidence": {
      "type": "string",
      "enum": ["confirmed_api", "probable_api", "ambiguous_service", "not_api"]
    },
    "metadata_completeness": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "documentation_quality_notes": {
      "type": "string"
    },
    "search_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_trust_tier": {
      "type": "string",
      "enum": ["tier_1", "tier_2", "tier_3", "tier_4"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "fetched_from", "raw_identifier"],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "fetched_from": {
          "type": "string",
          "format": "uri"
        },
        "raw_identifier": {
          "type": "string"
        },
        "raw_format": {
          "type": "string"
        },
        "last_seen_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
