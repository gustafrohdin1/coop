{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/score_breakdown.schema.json",
  "title": "ScoreBreakdown",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "discovery_relevance",
    "implementation_readiness",
    "metadata_completeness",
    "penalties",
    "total_score",
    "score_version"
  ],
  "properties": {
    "discovery_relevance": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "implementation_readiness": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "metadata_completeness": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "penalties": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "weight"],
        "properties": {
          "code": {
            "type": "string"
          },
          "weight": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "total_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "score_version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+)*$"
    }
  }
}
