{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "coop Agent Manifest",
  "type": "object",
  "required": ["id", "version", "title"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique agent identifier (e.g. 'network-overview')"
    },
    "version": {
      "type": "string",
      "description": "Semantic version (e.g. '1.0.0')"
    },
    "title": {
      "type": "string",
      "description": "Display name shown in handlers"
    },
    "description": {
      "type": "string",
      "description": "What this agent does"
    },
    "script": {
      "type": "string",
      "description": "Path to bash script, relative to manifest file"
    },
    "input_schema": {
      "type": "object",
      "description": "JSON schema for input parameters"
    },
    "output_schema": {
      "type": "object",
      "description": "JSON schema for structured output"
    },
    "constraints": {
      "type": "object",
      "properties": {
        "timeout":        { "type": "integer", "description": "Timeout in seconds" },
        "requires_admin": { "type": "boolean" },
        "network_allowed":{ "type": "boolean" }
      }
    }
  }
}
